# SwitchBot API 認証情報
# このファイルをコピーして .env を作成し、実際の値を設定してください
# cp .env.example .env

# SwitchBot APIトークン
# SwitchBotアプリ → プロフィール → 設定 → アプリバージョン(10回タップ) → トークン
SWITCHBOT_TOKEN=your_token_here

# SwitchBot APIシークレット
# SwitchBotアプリ → プロフィール → 設定 → アプリバージョン(10回タップ) → クライアントシークレット
SWITCHBOT_SECRET=your_secret_here
